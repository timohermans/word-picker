# Build stage
FROM golang:1.26 AS builder

ARG APP_NAME="migrate"

WORKDIR /app

# Download dependencies first for better layer caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build static binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o app ./cmd/${APP_NAME}

# Runtime stage
FROM scratch

WORKDIR /app

COPY --from=builder /app/app .
COPY --from=builder /app/internal/migrations ./internal/migrations

CMD ["./app"]